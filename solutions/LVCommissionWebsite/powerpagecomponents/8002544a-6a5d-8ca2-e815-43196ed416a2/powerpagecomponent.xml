&lt;div class="row sectionBlockLayout text-start" style="min-height: auto; padding: 8px;"&gt;
    &lt;div class="container" style="display: flex; flex-wrap: wrap;"&gt;
      &lt;div class="col-lg-12 columnBlockLayout" style="padding: 16px; margin: 60px 0px; min-height: 200px;"&gt;

        &lt;h1&gt;Developer &amp; Testing Pages&lt;/h1&gt;
        &lt;p class="text-muted"&gt;Utility pages for development, testing, and diagnostics&lt;/p&gt;
        &lt;p class="text-muted"&gt;&lt;small&gt;&lt;i class="fas fa-info-circle"&gt;&lt;/i&gt; Click on any description to expand/collapse details&lt;/small&gt;&lt;/p&gt;

        &lt;div class="table-responsive mt-4"&gt;
          &lt;table class="table table-striped table-hover"&gt;
            &lt;thead class="table-dark"&gt;
              &lt;tr&gt;
                &lt;th style="width: 180px;"&gt;Page&lt;/th&gt;
                &lt;th&gt;Description&lt;/th&gt;
              &lt;/tr&gt;
            &lt;/thead&gt;
            &lt;tbody&gt;
              &lt;tr&gt;
                &lt;td&gt;&lt;a href="/lvcpdev" target="_blank"&gt;/lvcpdev&lt;/a&gt;&lt;/td&gt;
                &lt;td&gt;
                  &lt;div class="page-description"&gt;
                    &lt;div class="description-header" onclick="toggleDescription(this)"&gt;
                      &lt;strong&gt;Developer Testing Console&lt;/strong&gt; - Comprehensive development tool with multiple sections
                      &lt;i class="fas fa-chevron-down float-end"&gt;&lt;/i&gt;
                    &lt;/div&gt;
                    &lt;div class="description-details" style="display: none;"&gt;
                      &lt;ul class="mb-0 mt-2"&gt;
                        &lt;li&gt;&lt;strong&gt;User Information&lt;/strong&gt;: View current user details, roles, branch/region assignments&lt;/li&gt;
                        &lt;li&gt;&lt;strong&gt;Setup Query Variables&lt;/strong&gt;: Display all setup query variables (is_admin, userBranchList, etc.)&lt;/li&gt;
                        &lt;li&gt;&lt;strong&gt;API Calls&lt;/strong&gt;: Interactive API testing interface with multiple endpoints (Business Central OData, Dataverse, Power Pages), supports GET/POST/DELETE/PUT/PATCH methods, includes headers and POST data configuration&lt;/li&gt;
                        &lt;li&gt;&lt;strong&gt;JavaScript Functions&lt;/strong&gt;: Execute various utility functions (web role management, approval deletion, log operations, local storage management)&lt;/li&gt;
                        &lt;li&gt;&lt;strong&gt;Logs&lt;/strong&gt;: Query and filter system logs with date range, user, kind, and detail filters&lt;/li&gt;
                        &lt;li&gt;&lt;strong&gt;Commission Approvals&lt;/strong&gt;: View recent commission approval records&lt;/li&gt;
                      &lt;/ul&gt;
                      &lt;p class="mb-0 mt-2 text-muted"&gt;&lt;em&gt;Primary tool for development, debugging, and API testing.&lt;/em&gt;&lt;/p&gt;
                    &lt;/div&gt;
                  &lt;/div&gt;
                &lt;/td&gt;
              &lt;/tr&gt;
              &lt;tr&gt;
                &lt;td&gt;&lt;a href="/lvcpx1" target="_blank"&gt;/lvcpx1&lt;/a&gt;&lt;/td&gt;
                &lt;td&gt;
                  &lt;div class="page-description"&gt;
                    &lt;div class="description-header" onclick="toggleDescription(this)"&gt;
                      &lt;strong&gt;Data Change Detection System&lt;/strong&gt; - Hash-based monitoring tool for detecting data changes
                      &lt;i class="fas fa-chevron-down float-end"&gt;&lt;/i&gt;
                    &lt;/div&gt;
                    &lt;div class="description-details" style="display: none;"&gt;
                      &lt;ul class="mb-0 mt-2"&gt;
                        &lt;li&gt;Calculates SHA-256 hashes of table data (branches, periods)&lt;/li&gt;
                        &lt;li&gt;Compares current data against stored hashes to detect changes&lt;/li&gt;
                        &lt;li&gt;Stores hashes in browser localStorage for comparison across sessions&lt;/li&gt;
                        &lt;li&gt;Useful for monitoring when reference data tables are modified&lt;/li&gt;
                      &lt;/ul&gt;
                    &lt;/div&gt;
                  &lt;/div&gt;
                &lt;/td&gt;
              &lt;/tr&gt;
              &lt;tr&gt;
                &lt;td&gt;&lt;a href="/lvcpx2" target="_blank"&gt;/lvcpx2&lt;/a&gt;&lt;/td&gt;
                &lt;td&gt;
                  &lt;div class="page-description"&gt;
                    &lt;div class="description-header" onclick="toggleDescription(this)"&gt;
                      &lt;strong&gt;Minimal Test Page&lt;/strong&gt; - Simple placeholder page
                      &lt;i class="fas fa-chevron-down float-end"&gt;&lt;/i&gt;
                    &lt;/div&gt;
                    &lt;div class="description-details" style="display: none;"&gt;
                      &lt;p class="mb-0 mt-2"&gt;Displays "X2". Used for basic page rendering tests or as a template starting point.&lt;/p&gt;
                    &lt;/div&gt;
                  &lt;/div&gt;
                &lt;/td&gt;
              &lt;/tr&gt;
              &lt;tr&gt;
                &lt;td&gt;&lt;a href="/lvcpx3" target="_blank"&gt;/lvcpx3&lt;/a&gt;&lt;/td&gt;
                &lt;td&gt;
                  &lt;div class="page-description"&gt;
                    &lt;div class="description-header" onclick="toggleDescription(this)"&gt;
                      &lt;strong&gt;Entity List Example&lt;/strong&gt; - Demonstrates entity list functionality
                      &lt;i class="fas fa-chevron-down float-end"&gt;&lt;/i&gt;
                    &lt;/div&gt;
                    &lt;div class="description-details" style="display: none;"&gt;
                      &lt;ul class="mb-0 mt-2"&gt;
                        &lt;li&gt;Displays text "X3 ex three"&lt;/li&gt;
                        &lt;li&gt;Includes embedded entity list: "Rodj All branch lvnCommissionBranches"&lt;/li&gt;
                        &lt;li&gt;Shows modern entity list with natural language search enabled&lt;/li&gt;
                      &lt;/ul&gt;
                      &lt;p class="mb-0 mt-2 text-muted"&gt;&lt;em&gt;Example implementation of Power Pages entity list component.&lt;/em&gt;&lt;/p&gt;
                    &lt;/div&gt;
                  &lt;/div&gt;
                &lt;/td&gt;
              &lt;/tr&gt;
              &lt;tr&gt;
                &lt;td&gt;&lt;a href="/lvxcpquery" target="_blank"&gt;/lvxcpquery&lt;/a&gt;&lt;/td&gt;
                &lt;td&gt;
                  &lt;div class="page-description"&gt;
                    &lt;div class="description-header" onclick="toggleDescription(this)"&gt;
                      &lt;strong&gt;Advanced Data Query Tool&lt;/strong&gt; - Multi-table query interface with date filtering
                      &lt;i class="fas fa-chevron-down float-end"&gt;&lt;/i&gt;
                    &lt;/div&gt;
                    &lt;div class="description-details" style="display: none;"&gt;
                      &lt;ul class="mb-0 mt-2"&gt;
                        &lt;li&gt;&lt;strong&gt;Date Range Selection&lt;/strong&gt;: Quick presets (last hour, today, last 7/30 days) or custom date ranges&lt;/li&gt;
                        &lt;li&gt;&lt;strong&gt;Multiple Tables&lt;/strong&gt;: Query logs, loan officers, commissions, or branches&lt;/li&gt;
                        &lt;li&gt;&lt;strong&gt;User Filtering&lt;/strong&gt;: Regex-based filtering with presets to exclude/include specific users&lt;/li&gt;
                        &lt;li&gt;&lt;strong&gt;Dynamic Schema&lt;/strong&gt;: Table headers and columns adjust based on selected table&lt;/li&gt;
                        &lt;li&gt;&lt;strong&gt;API Integration&lt;/strong&gt;: Uses Power Pages Web API to fetch data dynamically&lt;/li&gt;
                      &lt;/ul&gt;
                      &lt;p class="mb-0 mt-2 text-muted"&gt;&lt;em&gt;Ideal for ad-hoc queries and data investigation across different entity types.&lt;/em&gt;&lt;/p&gt;
                    &lt;/div&gt;
                  &lt;/div&gt;
                &lt;/td&gt;
              &lt;/tr&gt;
              &lt;tr&gt;
                &lt;td&gt;&lt;a href="/lvxdata" target="_blank"&gt;/lvxdata&lt;/a&gt;&lt;/td&gt;
                &lt;td&gt;
                  &lt;div class="page-description"&gt;
                    &lt;div class="description-header" onclick="toggleDescription(this)"&gt;
                      &lt;strong&gt;User Activity Report&lt;/strong&gt; - 30-day user activity analytics and visualization
                      &lt;i class="fas fa-chevron-down float-end"&gt;&lt;/i&gt;
                    &lt;/div&gt;
                    &lt;div class="description-details" style="display: none;"&gt;
