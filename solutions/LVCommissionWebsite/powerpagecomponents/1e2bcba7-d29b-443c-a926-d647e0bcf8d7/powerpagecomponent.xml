e=\"font-size: 12px; color: #6c757d; margin-top: 15px; margin-bottom: 0;\"&gt;\n\t\t\t\t\t\t\t\t&lt;em&gt;This error has been automatically logged for administrative review.&lt;/em&gt;\n\t\t\t\t\t\t\t&lt;/p&gt;\n\t\t\t\t\t\t&lt;/div&gt;\n\t\t\t\t\t&lt;/div&gt;\n\n\t\t\t\t&lt;/div&gt;\n\n\t\t\t&lt;/div&gt;\n\t\t&lt;/div&gt;\n\t&lt;/div&gt;\n\n\t&lt;script&gt;\n\tfunction toggleDetails() {\n\t\tconst details = document.getElementById('technicalDetails');\n\t\tconst toggleText = document.getElementById('detailsToggleText');\n\t\tconst toggleIcon = document.getElementById('detailsToggleIcon');\n\n\t\tif (details.style.display === 'none') {\n\t\t\tdetails.style.display = 'block';\n\t\t\ttoggleText.textContent = 'Hide technical details';\n\t\t\ttoggleIcon.textContent = '▲';\n\t\t} else {\n\t\t\tdetails.style.display = 'none';\n\t\t\ttoggleText.textContent = 'Show technical details';\n\t\t\ttoggleIcon.textContent = '▼';\n\t\t}\n\t}\n\t&lt;/script&gt;\n\n\t&lt;div class=\"row sectionBlockLayout\" style=\"display: flex; flex-wrap: wrap; min-height: 315px; background: var(--portalThemeColor1);\"&gt;&lt;/div&gt;\n\n{% else %}\n\t{% comment %} Normal access denied page {% endcomment %}\n\t&lt;div class=\"row sectionBlockLayout\" style=\"display: flex; flex-wrap: wrap; min-height: 50px; background: var(--portalThemeColor2);\"&gt;&lt;/div&gt;\n\t&lt;div class=\"row sectionBlockLayout\" style=\"display: flex; flex-wrap: wrap; min-height: 50px; background: var(--portalThemeColor6);\"&gt;&lt;/div&gt;\n\t&lt;div class=\"row sectionBlockLayout\" style=\"display: flex; flex-wrap: wrap; text-align: left; min-height: 374px;\"&gt;\n\t  &lt;div class=\"container\" style=\"padding: 0px; display: flex; flex-wrap: wrap;\"&gt;\n\t    &lt;div class=\"col-lg-12 columnBlockLayout\" style=\"flex-grow: 1; display: flex; flex-direction: column; min-width: 300px; padding: 16px;\"&gt;&lt;img src=\"/Cat-PC.png\" alt=\"\" name=\"Cat-PC.png\" style=\"width: 200px; height: 161px; margin-left: auto; margin-right: auto;\"&gt;\n\t      &lt;h2 style=\"text-align: center; color: var(--portalThemeColor9);\"&gt;You don't have access to this&lt;/h2&gt;\n\t      &lt;p style=\"text-align: center; color: var(--portalThemeColor8);\"&gt;Check your credentials or ask your admin to request access&lt;/p&gt;\n\t    &lt;/div&gt;\n\t  &lt;/div&gt;\n\t&lt;/div&gt;\n{% endif %}\n&lt;div class=\"row sectionBlockLayout\" style=\"display: flex; flex-wrap: wrap; min-height: 315px; background: var(--portalThemeColor1);\"&gt;&lt;/div&gt;\n&lt;!-- Last modified Sat Aug 30 10:04AM --&gt;\n&lt;!-- Last modified Wed Oct 29 8:37AM --&gt;\n&lt;!-- Last modified Wed Oct 29 8:54AM --&gt;",
